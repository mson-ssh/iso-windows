<Window x:Class="WinISOBuilder.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinISOBuilder"
        Title="WinISO Builder"
        Width="680"
        Height="680"
        MinWidth="680"
        MinHeight="680"
        MaxWidth="680"
        MaxHeight="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Icon="logo/app.ico"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="{StaticResource BgLight}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Height="40"
                    Background="{StaticResource TitleBarBg}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="WinISO Builder"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,4,0">
                        <Button Content="&#xE921;"
                                Style="{StaticResource BrowseBtnStyle}"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="10"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Click="Minimize_Click"
                                ToolTip="Minimize"/>
                        <Button Content="&#xE8BB;"
                                Style="{StaticResource BrowseBtnStyle}"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="10"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Click="Close_Click"
                                ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Header -->
            <Border Grid.Row="1"
                    Margin="20,16,20,0"
                    Style="{StaticResource SectionCardStyle}"
                    Background="{StaticResource SurfaceAlt}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                                    <Canvas Width="1024" Height="1024">
                                        <Path Data="M112 16h736v992H112z" Fill="#EDF2F9"/>
                                        <Path Data="M480 528c-97.2 0-176 78.8-176 176s78.8 176 176 176 176-78.8 176-176-78.8-176-176-176z m0 208a32 32 0 1 1 0.016-64.016A32 32 0 0 1 480 736z" Fill="#FFFFFF"/>
                                        <Path Data="M480 752a48 48 0 1 0 0-96 48 48 0 0 0 0 96z m0-64a16 16 0 1 1 0 32 16 16 0 1 1 0-32zM896 128h-32V32a32 32 0 0 0-32-32H128a32 32 0 0 0-32 32v960a32 32 0 0 0 32 32h704a32 32 0 0 0 32-32V416h32a32 32 0 0 0 32-32V160a32 32 0 0 0-32-32z m-64 0H448a32 32 0 0 0-32 32v224a32 32 0 0 0 32 32h384v576H128V32h704v96zM480 896c106.032 0 192-85.968 192-192s-85.968-192-192-192c-106.048 0-192 85.968-192 192s85.952 192 192 192z m0-352c88.352 0 160 71.648 160 160s-71.648 160-160 160-160-71.648-160-160 71.648-160 160-160z" Fill="#8592A5"/>
                                        <Path Data="M572.912 330.672h-27.184v-116.56h27.184v116.56zM659.472 237.792c-0.8 1.28-1.632 2.24-2.512 2.88s-2.016 0.96-3.392 0.96a8.176 8.176 0 0 1-3.968-1.152c-1.408-0.768-3.008-1.648-4.816-2.592a38.336 38.336 0 0 0-6.112-2.608 24.688 24.688 0 0 0-7.824-1.152c-5.072 0-8.848 1.072-11.328 3.248a11.008 11.008 0 0 0-3.728 8.752c0 2.336 0.752 4.304 2.256 5.84s3.456 2.88 5.872 4c2.432 1.12 5.2 2.144 8.336 3.072 3.104 0.944 6.304 1.968 9.552 3.12 3.264 1.136 6.448 2.48 9.568 4.032 3.12 1.552 5.904 3.536 8.336 5.92 2.416 2.4 4.384 5.328 5.888 8.768 1.488 3.44 2.224 7.584 2.224 12.432 0 5.392-0.928 10.416-2.784 15.12a35.6 35.6 0 0 1-21.248 20.528 48.928 48.928 0 0 1-17.712 3.008c-3.632 0-7.312-0.368-11.072-1.12s-7.392-1.792-10.928-3.152a62.656 62.656 0 0 1-9.92-4.848 41.792 41.792 0 0 1-8.08-6.24l8-12.64a7.104 7.104 0 0 1 5.92-3.216c1.616 0 3.2 0.512 4.832 1.52 1.648 1.008 3.472 2.144 5.536 3.36 2.064 1.232 4.4 2.352 7.072 3.36 2.672 1.008 5.808 1.536 9.456 1.536 4.912 0 8.72-1.072 11.44-3.248 2.72-2.16 4.064-5.584 4.064-10.288a9.68 9.68 0 0 0-2.24-6.624c-1.488-1.712-3.456-3.12-5.872-4.256s-5.184-2.112-8.288-2.96c-3.088-0.864-6.272-1.792-9.52-2.848s-6.432-2.336-9.536-3.84-5.84-3.52-8.288-6a28.352 28.352 0 0 1-5.872-9.28c-1.504-3.696-2.24-8.288-2.24-13.712a32.96 32.96 0 0 1 10.384-23.92c3.424-3.248 7.616-5.84 12.56-7.792a46.672 46.672 0 0 1 17.04-2.928c3.584 0 7.04 0.288 10.432 0.848s6.608 1.392 9.648 2.48 5.872 2.384 8.512 3.92c2.64 1.52 4.992 3.232 7.072 5.152l-6.72 12.56zM796.288 272.352c0 8.416-1.472 16.272-4.368 23.52s-7.008 13.568-12.288 18.928-11.632 9.552-19.072 12.592c-7.456 3.04-15.696 4.56-24.784 4.56a65.168 65.168 0 0 1-24.784-4.56 56.432 56.432 0 0 1-19.168-12.592c-5.296-5.36-9.424-11.664-12.336-18.928s-4.336-15.088-4.336-23.52 1.44-16.288 4.336-23.536 7.024-13.552 12.336-18.88a57.072 57.072 0 0 1 19.168-12.56 65.408 65.408 0 0 1 24.784-4.56c9.072 0 17.328 1.536 24.784 4.608 7.44 3.056 13.776 7.264 19.056 12.592s9.376 11.632 12.288 18.88c2.912 7.28 4.384 15.088 4.384 23.456z m-27.696 0c0-5.76-0.752-10.96-2.256-15.568a32.592 32.592 0 0 0-6.432-11.712 27.6 27.6 0 0 0-10.288-7.36 35.232 35.232 0 0 0-13.84-2.56c-5.216 0-9.872 0.848-13.952 2.56-4.08 1.696-7.52 4.16-10.336 7.36a32.832 32.832 0 0 0-6.432 11.712c-1.488 4.608-2.24 9.792-2.24 15.568 0 5.808 0.752 11.008 2.24 15.632 1.504 4.624 3.664 8.528 6.432 11.728 2.816 3.184 6.256 5.648 10.336 7.312 4.08 1.68 8.736 2.512 13.952 2.512 5.184 0 9.792-0.832 13.84-2.512 4.064-1.664 7.488-4.128 10.288-7.312 2.816-3.2 4.96-7.104 6.432-11.728 1.504-4.608 2.256-9.808 2.256-15.632z" Fill="#FFFFFF"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="WINISO BUILDER"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Segoe UI"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="Offline image servicing for Windows installation media"
                                       Style="{StaticResource SubHeaderStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Border Style="{StaticResource StatusBadgeStyle}">
                                <Button Command="{Binding OpenAdminHelpCommand}"
                                        Style="{StaticResource BadgeButtonStyle}"
                                        Foreground="{StaticResource BadgeNeutralText}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Fill="{Binding AdminStatusColor}"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Text="ADMIN"
                                               Style="{StaticResource StatusBadgeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource StatusBadgeStyle}">
                                <Button Command="{Binding OpenDismHelpCommand}"
                                        Style="{StaticResource BadgeButtonStyle}"
                                        Foreground="{StaticResource BadgeNeutralText}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Fill="{Binding DismStatusColor}"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="DISM READY"
                                                   Style="{StaticResource StatusBadgeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource StatusBadgeStyle}" Margin="0">
                                <Button Command="{Binding OpenAdkDownloadCommand}"
                                        Style="{StaticResource BadgeButtonStyle}"
                                        Foreground="{StaticResource BadgeNeutralText}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Fill="{Binding AdkStatusColor}"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="ADK TOOLCHAIN"
                                                   Style="{StaticResource StatusBadgeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource StepCardStyle}"
                                Background="#e8f1ff"
                                Padding="12,8"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconDisc}"
                                      Style="{StaticResource HeaderIconStyle}"
                                      Width="14"
                                      Height="14"
                                      Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="SOURCE"
                                               Style="{StaticResource StatusBadgeTextStyle}"
                                               Foreground="{StaticResource Accent}"/>
                                    <TextBlock Text="{Binding SourceStepStatus}"
                                               Style="{StaticResource LabelStyle}"
                                               Foreground="{StaticResource Accent}"/>
                                    <TextBlock Text="ISO or extracted folder"
                                               Style="{StaticResource LabelStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource StepCardStyle}"
                                Background="#f2f9f4"
                                Padding="12,8"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconChip}"
                                      Style="{StaticResource HeaderIconStyle}"
                                      Fill="{StaticResource Success}"
                                      Width="14"
                                      Height="14"
                                      Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="DRIVERS"
                                               Style="{StaticResource StatusBadgeTextStyle}"
                                               Foreground="{StaticResource Success}"/>
                                    <TextBlock Text="{Binding DriverStepStatus}"
                                               Style="{StaticResource LabelStyle}"
                                               Foreground="{StaticResource Success}"/>
                                    <TextBlock Text="Recursive .inf injection"
                                               Style="{StaticResource LabelStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource StepCardStyle}"
                                Background="#f6f7fb"
                                Padding="12,8"
                                Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconTerminal}"
                                      Style="{StaticResource HeaderIconStyle}"
                                      Fill="{StaticResource TextSecondary}"
                                      Width="14"
                                      Height="14"
                                      Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="BUILD"
                                               Style="{StaticResource StatusBadgeTextStyle}"/>
                                    <TextBlock Text="{Binding BuildStepStatus}"
                                               Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="ISO packaging and output"
                                               Style="{StaticResource LabelStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="2"
                          FocusVisualStyle="{x:Null}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="20,12,20,0">

                <StackPanel>
                    <!-- Step 1: ISO Selection -->
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="1. Select Windows Source"
                                       Style="{StaticResource InfoStyle}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding IsoPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PathBoxStyle}"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Browse"
                                        Style="{StaticResource BrowseBtnStyle}"
                                        Click="SourceBrowse_Click"
                                        Margin="8,0,0,0"
                                        Width="80">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open ISO file"
                                                      Command="{Binding PlacementTarget.DataContext.BrowseIsoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Open extracted folder"
                                                      Command="{Binding PlacementTarget.DataContext.BrowseExtractedFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource LabelStyle}">
                                <Run Text="Source type: "/>
                                <Run Text="{Binding SourceTypeText}"
                                     Foreground="{StaticResource TextPrimary}"/>
                            </TextBlock>

                            <!-- ISO Info -->
                            <Border Background="{StaticResource InputBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="0"
                                    Padding="12"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding IsoReady, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding IsoInfo, FallbackValue='No ISO loaded'}"
                                               Foreground="{StaticResource Success}"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Foreground="{StaticResource TextSecondary}"
                                               FontFamily="Segoe UI"
                                               FontSize="11"
                                               Margin="0,4,0,4">
                                        <Run Text="Architecture: "/>
                                        <Run Text="{Binding EditionInfo}" Foreground="{StaticResource TextPrimary}"/>
                                    </TextBlock>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Editions"
                                                   Style="{StaticResource LabelStyle}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                                            <Button Content="ALL" Style="{StaticResource LinkBtnStyle}" Command="{Binding SelectAllCommand}" Margin="0,0,8,0"/>
                                            <Button Content="NONE" Style="{StaticResource LinkBtnStyle}" Command="{Binding DeselectAllCommand}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Background="#e9ecef" Margin="0,6,0,2" Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="INDEX" Style="{StaticResource StatusBadgeTextStyle}" Margin="8,4"/>
                                        <TextBlock Grid.Column="1" Text="EDITION" Style="{StaticResource StatusBadgeTextStyle}" Margin="8,4"/>
                                        <TextBlock Grid.Column="2" Text="ACTION" Style="{StaticResource StatusBadgeTextStyle}" Margin="8,4"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding Editions}"
                                                  Margin="0,2,0,0">
                                             <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel/>
                                                </ItemsPanelTemplate>
                                             </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="48"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="64"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding Index}"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontFamily="Consolas"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0"/>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontFamily="Segoe UI"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"/>

                                                    <Button Grid.Column="2"
                                                            Content="EXCLUDE"
                                                            Command="{Binding DataContext.RemoveEditionCommand, ElementName=RootWindow}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource LinkBtnStyle}"
                                                            Margin="8,0,0,0"
                                                            ToolTip="Exclude this edition from the output ISO"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource LabelStyle}">
                                        <Run Text="Remaining: "/>
                                        <Run Text="{Binding SelectedCount, FallbackValue=0}"
                                             Foreground="{StaticResource Accent}"/>
                                        <Run Text=" of "/>
                                        <Run Text="{Binding Editions.Count, FallbackValue=0, Mode=OneWay}"
                                             Foreground="{StaticResource TextPrimary}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Step 2: Driver Selection -->
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsoReady, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="2. Unattended Setup"
                                               Style="{StaticResource InfoStyle}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Create local ADMIN account and apply first-run policies"
                                               Style="{StaticResource LabelStyle}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Content="ENABLE"
                                          IsChecked="{Binding IsUnattendedEnabled}"
                                          VerticalAlignment="Center"
                                          FontFamily="Segoe UI"
                                          FontSize="11"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimary}"/>
                            </Grid>

                            <Grid Background="{StaticResource InputBg}"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Account" Style="{StaticResource LabelStyle}" Margin="10,6" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding UnattendedUserName, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Segoe UI"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{StaticResource TextPrimary}"
                                         Background="Transparent"
                                         BorderBrush="{StaticResource BorderColor}"
                                         BorderThickness="0,0,0,1"
                                         Padding="6,4"
                                         Margin="10,4"
                                         MaxLength="20"
                                         CharacterCasing="Upper"
                                         VerticalAlignment="Center"
                                         ToolTip="1-20 letters/numbers. Reserved names not allowed."/>
                                <TextBlock Grid.Row="1" Text="Password" Style="{StaticResource LabelStyle}" Margin="10,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="None" Style="{StaticResource LabelStyle}" Foreground="{StaticResource TextPrimary}" Margin="10,2"/>
                                <TextBlock Grid.Row="2" Text="Password expires" Style="{StaticResource LabelStyle}" Margin="10,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Never" Style="{StaticResource LabelStyle}" Foreground="{StaticResource TextPrimary}" Margin="10,2"/>
                                <TextBlock Grid.Row="3" Text="Locale" Style="{StaticResource LabelStyle}" Margin="10,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="English (United States)" Style="{StaticResource LabelStyle}" Foreground="{StaticResource TextPrimary}" Margin="10,2"/>
                                <TextBlock Grid.Row="4" Text="Time zone" Style="{StaticResource LabelStyle}" Margin="10,2" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="4" Grid.Column="1"
                                          ItemsSource="{Binding TimeZones}"
                                          SelectedItem="{Binding SelectedTimeZone}"
                                          FontFamily="Segoe UI"
                                          FontSize="12"
                                          Foreground="{StaticResource TextPrimary}"
                                          Background="Transparent"
                                          BorderBrush="{StaticResource BorderColor}"
                                          BorderThickness="0,0,0,1"
                                          Padding="4,3"
                                          Margin="10,2"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Text="Device encryption" Style="{StaticResource LabelStyle}" Margin="10,2"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="Disabled" Style="{StaticResource LabelStyle}" Foreground="{StaticResource TextPrimary}" Margin="10,2"/>
                                <TextBlock Grid.Row="6" Text="UAC" Style="{StaticResource LabelStyle}" Margin="10,2,10,6"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="Disabled" Style="{StaticResource LabelStyle}" Foreground="{StaticResource TextPrimary}" Margin="10,2,10,6"/>
                            </Grid>

                            <TextBlock Text="Lab mode warning: creates ADMIN without password, disables UAC, and prevents device encryption. Use only for trusted lab/internal deployments."
                                       Style="{StaticResource LabelStyle}"
                                       Foreground="{StaticResource Danger}"/>
                        </StackPanel>
                    </Border>

                    <!-- Step 3: Driver Selection -->
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsoReady, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="3. Select Driver Folder"
                                       Style="{StaticResource InfoStyle}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding DriverPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PathBoxStyle}"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Browse"
                                        Style="{StaticResource BrowseBtnStyle}"
                                        Command="{Binding BrowseDriverCommand}"
                                        Margin="8,0,0,0"
                                        Width="80"/>
                            </Grid>

                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource LabelStyle}">
                                <Run Text="Found: "/>
                                <Run Text="{Binding DriverCount, FallbackValue=0}"
                                     Foreground="{StaticResource Accent}"/>
                                <Run Text=" driver(s)"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,0,0,8"
                            Visibility="{Binding DriversReady, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="4. Output ISO" Style="{StaticResource InfoStyle}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding OutputPath}" Style="{StaticResource PathBoxStyle}"/>
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseBtnStyle}" Command="{Binding BrowseOutputCommand}" Margin="8,0,0,0" Width="80"/>
                            </Grid>
                            <TextBlock Text="{Binding BuildSummary}" Style="{StaticResource LabelStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Bar -->
            <Border Grid.Row="3"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,1,0,0"
                    Padding="0,12"
                    Margin="0,8,0,0">

                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status + Progress -->
                    <StackPanel HorizontalAlignment="Stretch">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Log Console"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="COPY" Style="{StaticResource LinkBtnStyle}" Command="{Binding CopyLogCommand}" Margin="0,0,8,0"/>
                                <Button Content="CLEAR" Style="{StaticResource LinkBtnStyle}" Command="{Binding ClearLogCommand}" Margin="0,0,8,0"/>
                                <Button Content="OPEN LOG" Style="{StaticResource LinkBtnStyle}" Command="{Binding OpenLogFolderCommand}"/>
                            </StackPanel>
                        </Grid>
                        <Border Background="#f8f9fb"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="0"
                                Padding="8"
                                Height="88">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Text="{Binding LogText}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- Build Actions -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <Button Content="CANCEL"
                                Style="{StaticResource BrowseBtnStyle}"
                                Width="86"
                                Height="38"
                                Padding="12,8"
                                Margin="0,0,8,0"
                                Command="{Binding CancelBuildCommand}"
                                Visibility="{Binding CanCancelBuild, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="{Binding BuildButtonText}"
                                Style="{StaticResource BuildBtnStyle}"
                                Width="132"
                                Height="38"
                                Padding="14,8"
                                Command="{Binding BuildCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Version line -->
            <TextBlock Grid.Row="4"
                       Text="Windows ADK / DISM required. Run as Administrator."
                       Foreground="{StaticResource TextSecondary}"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <Border Grid.RowSpan="5"
                    Background="#66000000"
                    Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="0"
                            Width="500"
                            Padding="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding DialogTitle}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Segoe UI"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DialogMessage}"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,18"/>
                            <Border Background="{StaticResource InputBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    Padding="8"
                                    Margin="0,0,0,18"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding IsDonateDialog, Converter={StaticResource BoolToVis}}">
                                <Image Source="asset/donate-qr.png"
                                       Width="300"
                                       Height="300"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{Binding DialogSecondaryText}"
                                        Style="{StaticResource BrowseBtnStyle}"
                                        Command="{Binding CancelDialogCommand}"
                                        Width="136"
                                        Padding="10,8"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding IsConfirmationDialog, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="{Binding DialogPrimaryText}"
                                    Style="{StaticResource DialogPrimaryBtnStyle}"
                                    Command="{Binding CloseDialogCommand}"
                                    Width="136"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
